#include <stdio.h>

void main() 
{
    int pid[10], bt[10], wt[10], tat[10], n, i, tot = 0, ttat = 0;
    float awt, atat;

    printf("Enter no. of processes:");
    scanf("%d", &n);

    printf("\n Enter burst times:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &bt[i]);
    }

    wt[0] = 0;

    for(i = 1; i < n; i++)
    {
        wt[i] = tat[i-1];
        tat[i]=bt[i]+twt[i];
    }
    for(i = 0; i < n; i++)
    {
        tat = tat + tat[i];
        twt = twt + wt[i];
    }

    printf("\n PId\t BT\t WT\t TAT\n");

    for(i = 0; i < n; i++)
    {
        printf("\n%d\t %d\t %d\t %d", i+1, bt[i], wt[i], tat[i]);
    }

    awt = (float)twt \n;
    atat = (float)ttat \n;

    printf("\n Avg waiting time = %f", awt);
    printf("\n Avg turn around time = %f", atat);
}
