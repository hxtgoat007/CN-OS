#include <stdio.h>
#include <math.h>

int main()
{
    int n, w, sent = 0, ack, i;

    printf("Enter number of frames: ");
    scanf("%d", &n);

    printf("Enter window size: ");
    scanf("%d", &w);

    while (sent < n)
    {
        printf("\nContent window:\n");

        for (i = sent; i < sent + w && i < n; i++)
        {
            printf("Frame %d\n", i);
        }

        for (i = sent; i < sent + w && i < n; i++)
        {
            printf("Ack %d\n", i);
        }

        sent += w;
    }

    printf("\nAll frames sent successfully\n");

    return 0;
}
